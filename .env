# Environnement
APP_ENV=development
SECRET_KEY=change-me-in-production

# CORS (séparés par des virgules)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# HuggingFace Inference API
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxx
HF_FOOD_MODEL=nateraw/food

# Google Vision API (optionnel)
GOOGLE_VISION_API_KEY=

# Ollama (LLM local) — lancer avec : ollama run llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# USDA FoodData Central (DEMO_KEY = 30 req/h, clé gratuite sur https://fdc.nal.usda.gov/)
USDA_API_KEY=DEMO_KEY

# MariaDB existante (BDD TPRE501 — pas de conversion nécessaire)
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=
MARIADB_DB=healthai_coaching

# MongoDB (local Docker)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=healthai_coach

# Backend TPRE501 (laisser vide si pas encore connecté)
# BACKEND_API_URL=http://localhost:8000
# BACKEND_API_KEY=

# Rate limiting (requêtes/minute par IP)
RATE_LIMIT_PER_MINUTE=30
